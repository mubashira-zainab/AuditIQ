# Copy this file to .env and fill in the values you need.
# Every setting here has a safe default in app/config.py -- .env only needs
# to override what's different for your environment.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Comma-separated list, or "*" for any origin (fine for local dev only)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Optional: set this to skip pasting an API key into every request.
# A key sent in the /api/analyze form field always overrides this.
GROQ_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile
MAX_UPLOAD_MB=15
SESSION_TTL_MINUTES=120
